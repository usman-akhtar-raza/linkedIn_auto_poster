NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/linkedin_agent?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-strong-secret
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
# Set AI_MOCK=true to run without an OpenRouter key (canned dev responses)
AI_MOCK=false
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:4000/api/linkedin/oauth/callback
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-secret
TOKEN_ENCRYPTION_KEY_VERSION=1
TOKEN_ENCRYPTION_PREVIOUS_KEYS=
LINKEDIN_SCOPES=openid profile w_member_social
CSRF_SECRET=replace-with-csrf-secret
LOG_LEVEL=info
# Basic-auth credentials for the /admin/queues dashboard.
# Required in production (dashboard is disabled if unset there).
BULL_BOARD_USER=
BULL_BOARD_PASSWORD=
