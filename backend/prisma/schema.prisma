generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SCHEDULED
  PUBLISHED
  FAILED
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  RETRYING
  CANCELLED
}

enum JobType {
  RESEARCH
  GENERATE_POST
  GENERATE_IMAGE
  PUBLISH_POST
  ANALYTICS
}

enum ScheduleFrequency {
  DAILY
  WEEKLY
  MONTHLY
  WEEKDAYS
  WEEKENDS
  SPECIFIC_DATES
  CUSTOM_CRON
}

enum LinkedInConnectionStatus {
  CONNECTED
  DISCONNECTED
  EXPIRED
  REVOKED
  PERMISSION_ERROR
}

model User {
  id                String            @id @default(cuid())
  email             String            @unique
  name              String?
  passwordHash      String?
  timezone          String            @default("UTC")
  aiPreferences     Json              @default("{}")
  scheduleFrequency ScheduleFrequency @default(WEEKDAYS)
  scheduleCron      String?
  scheduleDates     DateTime[]
  scheduleTime       String            @default("09:00")
  lastScheduleRunAt  DateTime?
  nextScheduledRunAt DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  linkedinAccount LinkedInAccount?
  posts           Post[]
  promptTemplates PromptTemplate[]
  topics          Topic[]
  memories        AgentMemory[]
  jobs            Job[]
  oauthStates     OAuthState[]
  auditLogs       AuditLog[]

  @@index([email])
}

model LinkedInAccount {
  id                       String                   @id @default(cuid())
  userId                   String                   @unique
  linkedinUserId           String
  memberUrn                String?
  vanityName               String?
  localizedFirstName       String?
  localizedLastName        String?
  profilePictureUrl        String?
  accessTokenCiphertext    String                   @map("accessToken")
  refreshTokenCiphertext   String?                  @map("refreshToken")
  tokenKeyVersion          Int                      @default(1)
  expiresAt                DateTime?
  scope                    String?
  connectionStatus         LinkedInConnectionStatus @default(CONNECTED)
  profile                  Json                     @default("{}")
  connectedAt              DateTime                 @default(now())
  disconnectedAt           DateTime?
  lastRefreshedAt          DateTime?
  lastPermissionErrorAt    DateTime?
  lastTokenValidationAt    DateTime?

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizations LinkedInOrganization[]

  @@index([linkedinUserId])
  @@index([connectionStatus])
  @@map("LinkedInAccount")
}

model LinkedInOrganization {
  id            String   @id @default(cuid())
  accountId     String
  organizationId String
  organizationUrn String
  localizedName String?
  role          String?
  raw           Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  account LinkedInAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, organizationId])
  @@index([organizationUrn])
}

model OAuthState {
  id        String   @id @default(cuid())
  userId    String
  stateHash String   @unique
  nonce     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Topic {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  source      String
  url         String?
  summary     String
  score       Float    @default(0)
  tags        String[]
  researchedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts Post[]

  @@index([userId, researchedAt])
}

model PromptTemplate {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  description String?
  systemPrompt String
  userPrompt   String
  version     Int      @default(1)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts Post[]

  @@index([userId, isDefault])
}

model Post {
  id               String     @id @default(cuid())
  userId           String
  topicId          String?
  promptTemplateId String?
  title            String
  hook             String
  content          String
  hashtags         String[]
  status           PostStatus @default(DRAFT)
  rejectionReason  String?
  scheduledFor     DateTime?
  approvedAt       DateTime?
  publishedAt      DateTime?
  linkedinPostUrn  String?
  metadata         Json       @default("{}")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic          Topic?          @relation(fields: [topicId], references: [id], onDelete: SetNull)
  promptTemplate PromptTemplate? @relation(fields: [promptTemplateId], references: [id], onDelete: SetNull)
  analytics      PostAnalytics?
  generatedImages GeneratedImage[]
  jobs           Job[]

  @@index([userId, status])
  @@index([scheduledFor])
}

model GeneratedImage {
  id        String   @id @default(cuid())
  postId    String
  prompt    String
  provider  String
  imageUrl  String?
  storageKey String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PostAnalytics {
  id             String   @id @default(cuid())
  postId         String   @unique
  likes          Int      @default(0)
  comments       Int      @default(0)
  impressions    Int      @default(0)
  shares         Int      @default(0)
  clicks         Int      @default(0)
  followerGrowth Int      @default(0)
  ctr            Float    @default(0)
  engagementRate Float    @default(0)
  collectedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model AgentMemory {
  id        String   @id @default(cuid())
  userId    String
  type      String
  key       String
  value     Json
  weight    Float    @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, key])
  @@index([userId, type])
}

model Job {
  id          String    @id @default(cuid())
  userId      String
  postId      String?
  queueJobId  String?
  type        JobType
  status      JobStatus @default(QUEUED)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  payload     Json      @default("{}")
  error       String?
  scheduledFor DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([type, status])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  actor     String?
  action    String
  entity    String
  entityId  String?
  metadata  Json     @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
}
